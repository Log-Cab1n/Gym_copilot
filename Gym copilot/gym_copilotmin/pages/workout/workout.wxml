<wxs module="fmt" src="../../utils/format.wxs"></wxs>
<view class="page-container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="showDiscardDialog">
        <text class="nav-back-icon">←</text>
      </view>
      <view class="nav-title">
        <text>记录训练</text>
        <view wx:if="{{isUsingTemplate}}" class="template-badge">模板</view>
      </view>
      <view class="nav-action">
        <button wx:if="{{!isSaving}}" class="finish-btn-top" bindtap="finishWorkout">完成</button>
      </view>
    </view>
  </view>

  <!-- 主体内容 -->
  <scroll-view class="main-content" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 计时器区域 -->
    <view class="timer-section">
      <block wx:if="{{!isTimerRunning}}">
        <!-- 开始按钮 -->
        <view class="start-button-container">
          <view class="pulse-ring" style="transform: scale({{pulseScale * 1.2}});"></view>
          <view class="start-button" bindtap="startTimer">
            <text class="start-icon">▶</text>
            <text class="start-text">开始</text>
          </view>
        </view>
      </block>
      <block wx:else>
        <!-- 计时器显示 -->
        <view class="timer-display">
          <text class="timer-digit">{{fmt.formatTime(elapsedMinutes, elapsedSeconds)}}</text>
          <view class="timer-indicator">
            <view class="glow-dot" style="{{glowStyle}}"></view>
          </view>
        </view>
      </block>
    </view>

    <!-- 训练部位选择 -->
    <view class="section-container">
      <text class="section-title">训练部位</text>
      <view class="body-part-grid">
        <view
          wx:for="{{bodyParts}}"
          wx:key="key"
          class="body-part-item {{selectedBodyPart === item.key ? 'selected' : ''}}"
          bindtap="selectBodyPart"
          data-tag="{{item.key}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 动作列表 -->
    <view class="sets-section">
      <block wx:if="{{sets.length === 0}}">
        <view class="empty-state">
          <text class="empty-icon">🏋️</text>
          <text class="empty-title">点击右下角按钮添加训练动作</text>
          <text class="empty-subtitle">开始你的训练吧</text>
        </view>
      </block>
      <block wx:else>
        <view 
          wx:for="{{sets}}" 
          wx:key="index"
          class="set-card {{(item.weight === 0 && item.reps === 0) ? 'template-set' : ''}}"
          bindtap="editSet"
          data-index="{{index}}"
        >
          <view class="set-left">
            <view class="set-number {{(item.weight === 0 && item.reps === 0) ? 'template-number' : ''}}">
              <text>{{index + 1}}</text>
            </view>
            <view class="set-info">
              <text class="set-name">{{item.exerciseName}}</text>
              <block wx:if="{{(item.weight === 0 && item.reps === 0)}}">
                <view class="template-label">
                  <text>模板动作 - 点击修改</text>
                </view>
              </block>
              <block wx:else>
                <text class="set-detail">{{item.weight}} kg × {{item.reps}} 次</text>
              </block>
            </view>
          </view>
          <view class="set-delete" bindtap="removeSet" data-index="{{index}}">
            <text class="delete-icon">🗑</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 底部占位 -->
    <view style="height: 200rpx;"></view>
  </scroll-view>

  <!-- 疲劳度（底部固定） -->
  <view class="fatigue-section">
    <view class="fatigue-header">
      <text class="fatigue-title">疲劳度</text>
      <view class="fatigue-value">
        <text>{{fatigueLevel}} / 10</text>
      </view>
    </view>
    <slider 
      class="fatigue-slider"
      min="1" 
      max="10" 
      value="{{fatigueLevel}}" 
      step="1"
      block-size="16"
      activeColor="#F8FAFC"
      backgroundColor="#2D3748"
      block-color="#F8FAFC"
      bindchange="onFatigueChange"
    />
    <view class="fatigue-labels">
      <view class="fatigue-label">
        <text>😊</text>
        <text>轻松</text>
      </view>
      <view class="fatigue-label">
        <text>力竭</text>
        <text>😫</text>
      </view>
    </view>
  </view>

  <!-- 添加动作浮动按钮 -->
  <view wx:if="{{selectedBodyPart}}" class="fab" bindtap="showAddModal">
    <text class="fab-icon">+</text>
  </view>
</view>

<!-- 添加动作底部弹窗 -->
<view class="modal-mask {{showAddModal ? 'show' : ''}}" bindtap="hideAddModal"></view>
<view class="modal-popup {{showAddModal ? 'show' : ''}}">
  <view class="modal-handle"></view>
  <view class="modal-title">添加第 {{sets.length + 1}} 组</view>
  
  <view class="modal-form">
    <view class="form-row">
      <text class="form-label">动作</text>
      <picker mode="selector" range="{{availableExercises}}" range-key="name" bindchange="onExerciseChange">
        <view class="form-picker">
          <text wx:if="{{selectedExercise}}">{{selectedExercise.name}}</text>
          <text wx:else class="placeholder">选择动作</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-row three-col">
      <view class="form-group">
        <text class="form-label">重量</text>
        <view class="form-input-wrap">
          <input type="digit" class="form-input" placeholder="0" value="{{weight}}" bindinput="onWeightInput" />
          <text class="input-suffix">kg</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">次数</text>
        <view class="form-input-wrap">
          <input type="number" class="form-input" placeholder="0" value="{{reps}}" bindinput="onRepsInput" />
          <text class="input-suffix">次</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">组数</text>
        <view class="form-input-wrap">
          <input type="number" class="form-input" placeholder="1" value="{{setsCount}}" bindinput="onSetsCountInput" />
          <text class="input-suffix">组</text>
        </view>
      </view>
    </view>
  </view>

  <button class="btn-primary modal-btn" bindtap="addSet">添加</button>
</view>

<!-- 编辑模板动作弹窗 -->
<view class="modal-mask {{showEditModal ? 'show' : ''}}" bindtap="hideEditModal"></view>
<view class="modal-popup {{showEditModal ? 'show' : ''}}">
  <view class="modal-handle"></view>
  <view class="modal-title">编辑 {{editingSet ? editingSet.exerciseName : ''}}</view>
  
  <view class="modal-form">
    <view class="form-row two-col">
      <view class="form-group">
        <text class="form-label">重量</text>
        <view class="form-input-wrap">
          <input type="digit" class="form-input" placeholder="0" value="{{editWeight}}" bindinput="onEditWeightInput" />
          <text class="input-suffix">kg</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">次数</text>
        <view class="form-input-wrap">
          <input type="number" class="form-input" placeholder="0" value="{{editReps}}" bindinput="onEditRepsInput" />
          <text class="input-suffix">次</text>
        </view>
      </view>
    </view>
  </view>

  <button class="btn-primary modal-btn" bindtap="saveEditSet">保存</button>
</view>

<!-- 训练总结弹窗 -->
<view class="modal-mask {{showSummaryModal ? 'show' : ''}}" bindtap="hideSummaryModal"></view>
<view class="modal-popup {{showSummaryModal ? 'show' : ''}}">
  <view class="modal-handle"></view>
  <view class="modal-title">训练总结</view>
  
  <view class="summary-content" wx:if="{{summaryData}}">
    <view class="summary-row">
      <text class="summary-label">训练部位</text>
      <text class="summary-value">{{summaryData.bodyPart}}</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">训练时长</text>
      <text class="summary-value">{{summaryData.duration}} 分钟</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">动作组数</text>
      <text class="summary-value">{{summaryData.setsCount}} 组</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">疲劳度</text>
      <text class="summary-value">{{summaryData.fatigueLevel}} / 10</text>
    </view>
  </view>

  <view class="modal-actions">
    <button class="btn-secondary modal-action-btn" bindtap="hideSummaryModal">继续训练</button>
    <button class="btn-primary modal-action-btn" bindtap="confirmFinishWorkout">保存记录</button>
  </view>
</view>

<!-- 放弃训练弹窗 -->
<view class="modal-mask {{showDiscardModal ? 'show' : ''}}" bindtap="hideDiscardModal"></view>
<view class="modal-popup {{showDiscardModal ? 'show' : ''}}">
  <view class="modal-title" style="text-align: center;">放弃训练？</view>
  <view class="discard-content">
    <text>确定要放弃当前训练吗？已记录的数据将不会保存。</text>
  </view>
  <view class="modal-actions">
    <button class="btn-secondary modal-action-btn" bindtap="hideDiscardModal">继续训练</button>
    <button class="btn-danger modal-action-btn" bindtap="confirmDiscard">放弃</button>
  </view>
</view>