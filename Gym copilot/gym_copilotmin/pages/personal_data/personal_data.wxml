<view class="container">
  <!-- 顶部操作栏 -->
  <view class="page-header">
    <text class="page-header-title">身体数据追踪</text>
    <view class="record-btn" bindtap="showAdd">+ 记录</view>
  </view>

  <!-- 最新数据卡片 -->
  <view class="latest-card" wx:if="{{latestData}}">
    <text class="latest-title">最新数据</text>
    <text class="latest-date">{{latestData.recordDate}}</text>
    <view class="latest-metrics">
      <view class="latest-metric" wx:if="{{latestData.weight}}">
        <text class="latest-value">{{latestData.weight}}</text>
        <text class="latest-label">体重(kg)</text>
      </view>
      <view class="latest-metric" wx:if="{{latestData.height}}">
        <text class="latest-value">{{latestData.height}}</text>
        <text class="latest-label">身高(cm)</text>
      </view>
      <view class="latest-metric" wx:if="{{latestData.bodyFat}}">
        <text class="latest-value">{{latestData.bodyFat}}%</text>
        <text class="latest-label">体脂</text>
      </view>
      <view class="latest-metric" wx:if="{{latestData.muscleMass}}">
        <text class="latest-value">{{latestData.muscleMass}}</text>
        <text class="latest-label">肌肉量(kg)</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{bodyData.length === 0}}">
    <text class="empty-text">暂无身体数据记录</text>
    <text class="empty-subtext">点击右上角「记录」添加第一条数据</text>
  </view>

  <!-- 历史记录列表 -->
  <view class="history-section" wx:if="{{bodyData.length > 0}}">
    <text class="section-title">历史记录</text>
    <view class="history-list">
      <view class="history-card" wx:for="{{bodyData}}" wx:key="id">
        <view class="history-header">
          <text class="history-date">{{item.recordDate}}</text>
          <view class="delete-btn" data-id="{{item.id}}" bindtap="deleteBodyData"></view>
        </view>
        <view class="history-metrics">
          <view class="history-metric" wx:if="{{item.weight}}">
            <text class="history-metric-label">体重</text>
            <text class="history-metric-value">{{item.weight}}kg</text>
          </view>
          <view class="history-metric" wx:if="{{item.height}}">
            <text class="history-metric-label">身高</text>
            <text class="history-metric-value">{{item.height}}cm</text>
          </view>
          <view class="history-metric" wx:if="{{item.bodyFat}}">
            <text class="history-metric-label">体脂</text>
            <text class="history-metric-value">{{item.bodyFat}}%</text>
          </view>
          <view class="history-metric" wx:if="{{item.muscleMass}}">
            <text class="history-metric-label">肌肉量</text>
            <text class="history-metric-value">{{item.muscleMass}}kg</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 添加数据弹窗 -->
<view class="modal-mask" wx:if="{{showAddModal}}" bindtap="hideAdd"></view>
<view class="modal-popup" wx:if="{{showAddModal}}">
  <view class="modal-header">
    <text>记录身体数据</text>
    <text class="modal-close" bindtap="hideAdd">✕</text>
  </view>
  <view class="modal-body">
    <text class="modal-label">日期</text>
    <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
      <view class="modal-input">{{recordDate}}</view>
    </picker>
    <text class="modal-label">体重 (kg)</text>
    <input class="modal-input" type="digit" placeholder="输入体重" value="{{weight}}" bindinput="onWeightInput" />
    <text class="modal-label">身高 (cm)</text>
    <input class="modal-input" type="digit" placeholder="输入身高" value="{{height}}" bindinput="onHeightInput" />
    <text class="modal-label">体脂 (%)</text>
    <input class="modal-input" type="digit" placeholder="输入体脂率" value="{{bodyFat}}" bindinput="onBodyFatInput" />
    <text class="modal-label">肌肉量 (kg)</text>
    <input class="modal-input" type="digit" placeholder="输入肌肉量" value="{{muscleMass}}" bindinput="onMuscleMassInput" />
    <button class="modal-btn primary" bindtap="saveBodyData">保存</button>
  </view>
</view>
