page {
  padding-bottom: 200rpx;
}

.header-section {
  padding: 40rpx 40rpx 32rpx;
  margin-bottom: 8rpx;
}

.section-label {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 600;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.stat-value {
  font-size: 80rpx;
  font-weight: 200;
  color: #F8FAFC;
  line-height: 1;
  letter-spacing: -2rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 16rpx;
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 100rpx;
  background: linear-gradient(to bottom, transparent, #2D3748, transparent);
  margin: 0 32rpx;
}

/* 记录卡片 */
.record-card {
  background: linear-gradient(145deg, #1A1F2E, #0B0F19);
  border-radius: 32rpx;
  padding: 36rpx;
  margin: 0 24rpx 24rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2), 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.record-card:active {
  transform: scale(0.98) translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.record-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.record-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: rgba(36, 43, 61, 0.8);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.tag-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.tag-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #F8FAFC;
}

.record-time {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 400;
}

.record-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #242B3D, #1A1F2E);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.record-exercises {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 20rpx;
  gap: 12rpx;
}

.exercise-text {
  font-size: 24rpx;
  color: #64748B;
  background-color: rgba(36, 43, 61, 0.6);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(11, 15, 25, 0.98), rgba(11, 15, 25, 0.9));
  backdrop-filter: blur(40rpx) saturate(1.2);
  -webkit-backdrop-filter: blur(40rpx) saturate(1.2);
  border-top: 1rpx solid rgba(45, 55, 72, 0.4);
  z-index: 100;
}

.action-btn {
  flex: 1;
  margin: 0 12rpx;
  padding: 28rpx 0;
  font-size: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: all 0.15s ease;
}

.action-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

/* 空状态优化 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
  color: #F8FAFC;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #64748B;
}