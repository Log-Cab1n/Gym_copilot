<wxs module="fmt" src="../../utils/format.wxs"></wxs>
<view class="container">
  <!-- 本周概览 -->
  <view class="header-section">
    <text class="section-label">本周概览</text>
    <view class="stats-row">
      <view class="stat-block">
        <text class="stat-value">{{weeklyWorkoutDays}}</text>
        <text class="stat-label">训练天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-block">
        <text class="stat-value">{{weeklyDuration}}</text>
        <text class="stat-label">总时长(分钟)</text>
      </view>
    </view>
  </view>

  <!-- 今日训练 -->
  <block wx:if="{{todayRecords.length > 0}}">
    <view class="section-title">今日训练</view>
    <view wx:for="{{todayRecords}}" wx:key="id" class="record-card">
      <view class="record-header">
        <view class="record-tag">
          <view class="tag-dot" style="background-color: {{tagColors[item.bodyPart]}};"></view>
          <text class="tag-name">{{tagNames[item.bodyPart]}}</text>
        </view>
        <text class="record-time">{{fmt.formatDateTime(item.dateTime)}}</text>
      </view>
      <view class="record-chips">
        <view class="chip">{{item.durationMinutes}}分钟</view>
        <view class="chip">{{item.exerciseSets.length}}组</view>
        <view class="chip">疲劳{{item.fatigueLevel}}</view>
      </view>
      <view class="record-exercises" wx:if="{{item.exerciseSets.length > 0}}">
        <text wx:for="{{item.exerciseSets}}" wx:key="index" wx:for-item="set" class="exercise-text">
          {{set.exerciseName}} {{set.weight}}kg×{{set.reps}}
        </text>
      </view>
    </view>
  </block>

  <!-- 历史记录 -->
  <view class="section-title">历史记录</view>
  
  <view wx:if="{{pastRecords.length === 0}}" class="empty-state">
    <view class="empty-icon">🏋️</view>
    <text class="empty-title">还没有历史记录</text>
    <text class="empty-subtitle">开始你的第一次训练吧</text>
  </view>

  <view wx:else>
    <view wx:for="{{pastRecords}}" wx:key="id" class="record-card">
      <view class="record-header">
        <view class="record-tag">
          <view class="tag-dot" style="background-color: {{tagColors[item.bodyPart]}};"></view>
          <text class="tag-name">{{tagNames[item.bodyPart]}}</text>
        </view>
        <text class="record-time">{{fmt.formatDateTime(item.dateTime)}}</text>
      </view>
      <view class="record-chips">
        <view class="chip">{{item.durationMinutes}}分钟</view>
        <view class="chip">{{item.exerciseSets.length}}组</view>
        <view class="chip">疲劳{{item.fatigueLevel}}</view>
      </view>
      <view class="record-exercises" wx:if="{{item.exerciseSets.length > 0}}">
        <text wx:for="{{item.exerciseSets}}" wx:key="index" wx:for-item="set" class="exercise-text">
          {{set.exerciseName}} {{set.weight}}kg×{{set.reps}}
        </text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions safe-area-bottom">
    <button class="btn-primary action-btn" bindtap="onStartWorkout">
      <text class="btn-icon">+</text>
      <text>开始训练</text>
    </button>
    <button class="btn-secondary action-btn" bindtap="onTemplates">
      <text class="btn-icon">📁</text>
      <text>训练模板</text>
    </button>
  </view>
</view>