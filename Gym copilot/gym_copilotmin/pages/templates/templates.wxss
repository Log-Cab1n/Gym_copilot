page {
  background-color: #0B0F19;
}

.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
}

/* 模板卡片 */
.template-card {
  background: linear-gradient(145deg, #1A1F2E, #1A1F2E);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  position: relative;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.template-card:active {
  transform: scale(0.97);
}

.template-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.template-info {
  flex: 1;
  margin-right: 16rpx;
}

.template-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
  display: block;
  margin-bottom: 8rpx;
}

.template-tag {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
}

.delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.delete-btn:active {
  transform: scale(0.9);
  background-color: rgba(207, 102, 121, 0.2);
}

.delete-icon {
  font-size: 36rpx;
  color: #64748B;
  line-height: 1;
  transition: color 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.delete-btn:active .delete-icon {
  color: #CF6679;
}

.template-exercises {
  margin-bottom: 20rpx;
}

.exercise-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.exercise-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #F8FAFC;
  flex: 1;
}

.exercise-detail {
  font-size: 24rpx;
  font-weight: 600;
  color: #F8FAFC;
}

.template-footer {
  border-top: 1rpx solid rgba(45, 55, 72, 0.6);
  padding-top: 20rpx;
}

.template-date {
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
}

/* 浮动按钮 */
.fab-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  height: 96rpx;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  border-radius: 48rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4), 0 2rpx 8rpx rgba(0, 0, 0, 0.3), 0 0 0 1rpx rgba(232, 228, 225, 0.1);
  z-index: 50;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.fab-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4), 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

.fab-icon {
  font-size: 40rpx;
  font-weight: 300;
  margin-right: 12rpx;
  line-height: 1;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 700;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(8rpx);
  z-index: 100;
}

/* 底部弹窗 */
.modal-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1A1F2E, #1A1F2E);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  border-top: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.modal-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.6);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.modal-close {
  font-size: 32rpx;
  color: #64748B;
  padding: 8rpx;
  line-height: 1;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-close:active {
  transform: scale(0.9);
  color: #F8FAFC;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.modal-input {
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #F8FAFC;
  margin-bottom: 24rpx;
  height: auto;
  min-height: 84rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-input:focus {
  border-color: rgba(232, 228, 225, 0.3);
}

.modal-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #F8FAFC;
  margin-bottom: 16rpx;
  display: block;
}

/* 部位选择 */
.body-part-row {
  display: flex;
  flex-direction: row;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.body-part-item {
  flex: 1;
  padding: 20rpx 0;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
  text-align: center;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.body-part-item:active {
  transform: scale(0.95);
}

.body-part-active {
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  font-weight: 700;
  border-color: rgba(232, 228, 225, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.15);
}

/* 区域头部 */
.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.clear-btn {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.clear-btn:active {
  color: #F8FAFC;
  transform: scale(0.95);
}

/* 动作列表 */
.exercise-list {
  background: linear-gradient(145deg, rgba(36, 43, 61, 0.4), rgba(34, 34, 34, 0.3));
  border-radius: 14rpx;
  margin-bottom: 24rpx;
  max-height: 400rpx;
  overflow-y: auto;
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.exercise-checkbox-item {
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.5);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.exercise-checkbox-item:active {
  background-color: rgba(255, 255, 255, 0.03);
}

.exercise-checkbox-item:last-child {
  border-bottom: none;
}

.checkbox-label {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.checkbox-label checkbox {
  margin-right: 16rpx;
  transform: scale(0.8);
}

.checkbox-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #F8FAFC;
}

.empty-exercises {
  padding: 40rpx;
  text-align: center;
  color: #64748B;
  font-size: 26rpx;
  font-weight: 500;
}

/* 已选择标签 */
.selected-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  max-height: 200rpx;
  overflow-y: auto;
}

.selected-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 28rpx;
  border: 1rpx solid rgba(232, 228, 225, 0.15);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.selected-tag:active {
  transform: scale(0.95);
}

.tag-name {
  font-size: 24rpx;
  color: #F8FAFC;
  font-weight: 600;
  margin-right: 8rpx;
}

.tag-detail {
  font-size: 22rpx;
  font-weight: 500;
  color: #F8FAFC;
  margin-right: 12rpx;
}

.tag-edit {
  margin-right: 12rpx;
  padding: 4rpx;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.tag-edit:active {
  transform: scale(0.9);
}

.tag-remove {
  padding: 4rpx;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.tag-remove:active {
  transform: scale(0.9);
}

.tag-icon {
  font-size: 22rpx;
  color: #64748B;
  line-height: 1;
  transition: color 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.tag-remove:active .tag-icon {
  color: #CF6679;
}

/* 保存按钮 */
.save-area {
  margin-top: 16rpx;
}

.btn-save {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(232, 228, 225, 0.15), 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.btn-save:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.1);
}

.btn-save::after {
  border: none;
}

.btn-disabled {
  opacity: 0.4;
}

/* 配置弹窗 */
.config-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1A1F2E, #1A1F2E);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 102;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.config-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.6);
}

.config-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.config-body {
  padding: 32rpx;
}

.config-row {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.config-input-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.config-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  margin-bottom: 12rpx;
}

.config-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 14rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
}

.config-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #F8FAFC;
  text-align: center;
  background: transparent;
  min-height: 60rpx;
  height: auto;
  padding: 0;
}

.config-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  margin-left: 8rpx;
}

.config-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  padding: 28rpx 0;
  background: transparent;
  color: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(45, 55, 72, 0.6);
  text-align: center;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.btn-cancel:active {
  transform: scale(0.97);
  background-color: rgba(255, 255, 255, 0.03);
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  padding: 28rpx 0;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(232, 228, 225, 0.15);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.btn-confirm:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.1);
}

.btn-confirm::after {
  border: none;
}