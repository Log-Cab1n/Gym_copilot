<wxs module="fmt" src="../../utils/format.wxs"></wxs>
<view class="container">
  <!-- 当前计划 -->
  <view class="card" wx:if="{{activePlan}}">
    <view class="flex-between" style="margin-bottom: 24rpx;">
      <view>
        <text class="plan-name">{{activePlan.name}}</text>
        <text class="plan-date">{{fmt.formatPlanDate(activePlan.startDate)}} - {{fmt.formatPlanDate(activePlan.endDate)}}</text>
      </view>
      <view class="active-badge">进行中</view>
    </view>
    
    <!-- 进度圆环 -->
    <view class="progress-ring-container">
      <view class="progress-ring-wrapper">
        <svg class="progress-ring" viewBox="0 0 120 120">
          <circle class="progress-ring-bg" cx="60" cy="60" r="54"/>
          <circle class="progress-ring-fill" cx="60" cy="60" r="54" 
            stroke-dasharray="{{339.292}}" 
            stroke-dashoffset="{{339.292 * (1 - activePlan.progress)}}"/>
        </svg>
        <view class="progress-text">
          <text class="progress-percent">{{activePlan.progressPercent}}%</text>
          <text class="progress-label">已完成</text>
        </view>
      </view>
    </view>
    
    <view class="plan-stats">
      <view class="plan-stat">
        <text class="plan-stat-value">{{activePlan.daysPerWeek}}天</text>
        <text class="plan-stat-label">每周训练</text>
      </view>
      <view class="plan-stat-divider"></view>
      <view class="plan-stat">
        <text class="plan-stat-value">{{remainingDays}}天</text>
        <text class="plan-stat-label">剩余天数</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-title">暂无训练计划</text>
    <text class="empty-subtitle">创建一个训练计划开始吧</text>
    <button class="btn-primary" bindtap="showAdd" style="margin-top: 40rpx;">创建计划</button>
  </view>

  <!-- 本周训练日历 -->
  <view class="card" wx:if="{{activePlan}}">
    <text class="section-title">本周训练计划</text>
    <view class="week-calendar">
      <view wx:for="{{weekDays}}" wx:key="*this" class="week-day">
        <view class="day-circle {{weekCompletion[index] ? 'day-completed' : ''}}">
          <text wx:if="{{weekCompletion[index]}}">✓</text>
          <text wx:else>{{index + 1}}</text>
        </view>
        <text class="day-label {{weekCompletion[index] ? 'day-label-completed' : ''}}">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 历史计划 -->
  <view wx:if="{{plans.length > 0}}">
    <text class="section-title">所有周期</text>
    <view wx:for="{{plans}}" wx:key="id" class="plan-card">
      <view class="plan-header">
        <view style="display: flex; flex-direction: row; align-items: center; gap: 16rpx;">
          <text class="plan-name">{{item.name}}</text>
          <view wx:if="{{item._isActive}}" class="active-badge">进行中</view>
        </view>
        <view class="delete-btn" bindtap="deletePlan" data-id="{{item.id}}"></view>
      </view>
      <text class="plan-date">{{fmt.formatPlanDate(item.startDate)}} - {{fmt.formatPlanDate(item.endDate)}}</text>
      <text class="plan-info">每周{{item.daysPerWeek}}练 · {{item.workoutDays}}</text>
      <view class="plan-progress-bar">
        <view class="plan-progress-track">
          <view class="plan-progress-fill" style="width: {{item.progressPercent}}%;"></view>
        </view>
        <text class="plan-progress-text">{{item.progressPercent}}%</text>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="showAdd">+</view>
</view>

<!-- 添加弹窗 -->
<view class="modal-mask" wx:if="{{showAddModal}}" bindtap="hideAdd"></view>
<view class="modal-popup" wx:if="{{showAddModal}}">
  <view class="modal-header">
    <text>创建训练计划</text>
    <view class="modal-close" bindtap="hideAdd">✕</view>
  </view>
  <view class="modal-body">
    <input class="modal-input" placeholder="计划名称" value="{{planName}}" bindinput="onNameInput" />

    <text class="modal-label">起始日期</text>
    <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
      <view class="modal-input">{{startDate || '选择开始日期'}}</view>
    </picker>

    <text class="modal-label">结束日期</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
      <view class="modal-input">{{endDate || '选择结束日期'}}</view>
    </picker>

    <text class="modal-label">每周训练天数</text>
    <view class="flex-row" style="gap: 16rpx;">
      <view wx:for="{{[3,4,5,6]}}" wx:key="*this" class="tag-option {{daysPerWeek === item ? 'tag-option-active' : ''}}" bindtap="selectDaysPerWeek" data-days="{{item}}">
        {{item}}天
      </view>
    </view>

    <text class="modal-label">训练日</text>
    <view class="flex-row" style="flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx;">
      <view wx:for="{{weekDays}}" wx:key="*this" class="tag-option {{selectedDays[index] ? 'tag-option-active' : ''}}" bindtap="toggleDay" data-index="{{index}}">
        {{item}}
      </view>
    </view>

    <button class="btn-primary modal-btn" bindtap="addPlan">创建计划</button>
  </view>
</view>
