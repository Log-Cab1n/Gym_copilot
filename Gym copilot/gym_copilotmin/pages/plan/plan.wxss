.plan-card, .plan-header > view:first-child {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
  display: block;
  margin-bottom: 12rpx;
}

.plan-date {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  display: block;
  margin-bottom: 12rpx;
}

.plan-info {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  display: block;
}

.chip {
  padding: 8rpx 18rpx;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.chip:active {
  transform: scale(0.95);
}

.active-badge {
  padding: 8rpx 18rpx;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: inline-block;
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.2);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.active-badge:active {
  transform: scale(0.95);
}

/* 进度圆环 */
.progress-ring-container {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.progress-ring-wrapper {
  position: relative;
  width: 240rpx;
  height: 240rpx;
}

.progress-ring {
  width: 240rpx;
  height: 240rpx;
  transform: rotate(-90deg);
}

.progress-ring-bg {
  fill: none;
  stroke: #242B3D;
  stroke-width: 8;
}

.progress-ring-fill {
  fill: none;
  stroke: #F8FAFC;
  stroke-width: 8;
  stroke-linecap: round;
  transition: stroke-dashoffset 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}

.progress-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-percent {
  font-size: 52rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.progress-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
  margin-top: 8rpx;
}

/* 计划统计 */
.plan-stats {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(45, 55, 72, 0.6);
}

.plan-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.plan-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.plan-stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
  margin-top: 8rpx;
}

.plan-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, rgba(45, 55, 72, 0.8), transparent);
}

/* 本周日历 */
.week-calendar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding: 24rpx 0;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.day-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.day-circle:active {
  transform: scale(0.9);
}

.day-circle text {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
}

.day-completed {
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  border-color: rgba(232, 228, 225, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(232, 228, 225, 0.15), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.day-completed text {
  color: #0B0F19;
  font-weight: 700;
}

.day-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
}

.day-label-completed {
  color: #F8FAFC;
  font-weight: 600;
}

/* 进度条 */
.plan-progress-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 24rpx;
}

.plan-progress-track {
  flex: 1;
  height: 8rpx;
  background: linear-gradient(90deg, #1A1F2E, #242B3D);
  border-radius: 4rpx;
  overflow: hidden;
}

.plan-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #F8FAFC, #F0EDE9);
  border-radius: 4rpx;
  transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.plan-progress-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #64748B;
  margin-left: 16rpx;
  min-width: 60rpx;
  text-align: right;
}

/* 计划卡片 */
.plan-card {
  background: linear-gradient(145deg, #1A1F2E, #1A1F2E);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  position: relative;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.plan-card:active {
  transform: scale(0.97);
}

.plan-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(8rpx);
  z-index: 100;
}

.modal-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1A1F2E, #1A1F2E);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.modal-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.6);
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.modal-close {
  font-size: 32rpx;
  color: #64748B;
  padding: 8rpx;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-close:active {
  transform: scale(0.9);
  color: #F8FAFC;
}

.modal-body {
  padding: 32rpx;
}

.modal-input {
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #F8FAFC;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-input:focus {
  border-color: rgba(232, 228, 225, 0.3);
}

.modal-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
  margin-bottom: 16rpx;
  display: block;
}

.tag-option {
  padding: 16rpx 28rpx;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.tag-option:active {
  transform: scale(0.95);
}

.tag-option-active {
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  border-color: rgba(232, 228, 225, 0.3);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.15);
}

.modal-btn {
  width: 100%;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-btn:active {
  transform: scale(0.97);
}

.add-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  color: #0B0F19;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4), 0 2rpx 8rpx rgba(0, 0, 0, 0.3), 0 0 0 1rpx rgba(232, 228, 225, 0.1);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.add-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4), 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

.delete-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #CF6679, #D67889);
  position: relative;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.delete-btn:active {
  transform: scale(0.9);
}

.delete-btn::before,
.delete-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 2rpx;
  background-color: #fff;
}

.delete-btn::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.delete-btn::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}