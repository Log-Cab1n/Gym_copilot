.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(232, 228, 225, 0.15), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.avatar:active {
  transform: scale(0.95);
}

.avatar-icon {
  font-size: 48rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 12rpx;
}

.profile-desc {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3), 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.stat-card:active {
  transform: scale(0.97);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
}

.nav-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.6);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.nav-item:active {
  transform: scale(0.98);
  padding-left: 8rpx;
}

.nav-item:last-child {
  border-bottom: none;
}

.nav-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #F8FAFC;
}

.nav-arrow {
  font-size: 24rpx;
  color: #64748B;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.nav-item:active .nav-arrow {
  color: #F8FAFC;
  transform: translateX(4rpx);
}

.body-data-item {
  position: relative;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.6);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.body-data-item:active {
  transform: scale(0.98);
}

.body-date {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  display: block;
  margin-bottom: 12rpx;
}

.body-metrics {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
}

.body-metric {
  font-size: 26rpx;
  font-weight: 500;
  color: #F8FAFC;
}

.delete-btn {
  position: absolute;
  top: 24rpx;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #CF6679, #D67889);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.delete-btn:active {
  transform: scale(0.9);
}

.delete-btn::before,
.delete-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 2rpx;
  background-color: #fff;
}

.delete-btn::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.delete-btn::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(8rpx);
  z-index: 100;
}

.modal-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1A1F2E, #1A1F2E);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.modal-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.6);
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.modal-close {
  font-size: 32rpx;
  color: #64748B;
  padding: 8rpx;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-close:active {
  transform: scale(0.9);
  color: #F8FAFC;
}

.modal-body {
  padding: 32rpx;
}

.modal-input {
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #F8FAFC;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-input:focus {
  border-color: rgba(232, 228, 225, 0.3);
}

.modal-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #64748B;
  margin-bottom: 16rpx;
  display: block;
}

.modal-btn {
  width: 100%;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 16rpx;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.modal-btn:active {
  transform: scale(0.97);
}