.record-card {
  background: linear-gradient(145deg, #1A1F2E, #1A1F2E);
  border-radius: 28rpx;
  padding: 36rpx;
  margin: 24rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.record-card:active {
  transform: scale(0.97);
}

.record-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.tag-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #F8FAFC, #F0EDE9);
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.2);
}

.tag-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.record-time {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  margin-right: 20rpx;
}

.record-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.chip {
  padding: 8rpx 20rpx;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #F8FAFC;
  margin-right: 16rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.chip:active {
  transform: scale(0.95);
}

.record-exercises {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.exercise-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
  margin-right: 20rpx;
  margin-bottom: 8rpx;
}

.delete-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #CF6679, #D67889);
  position: relative;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.delete-btn:active {
  transform: scale(0.9);
}

.delete-btn::before,
.delete-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 2rpx;
  background-color: #fff;
}

.delete-btn::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.delete-btn::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
}