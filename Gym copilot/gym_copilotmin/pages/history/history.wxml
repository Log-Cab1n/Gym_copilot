<wxs module="fmt" src="../../utils/format.wxs"></wxs>
<view class="container">
  <view wx:if="{{records.length === 0}}" class="empty-state">
    <text class="empty-title">暂无训练记录</text>
    <text class="empty-subtitle">开始你的第一次训练吧</text>
  </view>

  <view wx:for="{{records}}" wx:key="id" class="record-card">
    <view class="record-header">
      <view class="flex-row">
        <view class="tag-dot" style="background-color: {{tagColors[item.bodyPart]}};"></view>
        <text class="tag-name">{{tagNames[item.bodyPart]}}</text>
      </view>
      <view class="flex-row">
        <text class="record-time">{{fmt.formatDateTime(item.dateTime)}}</text>
        <view class="delete-btn" bindtap="deleteRecord" data-id="{{item.id}}"></view>
      </view>
    </view>
    <view class="record-chips">
      <view class="chip">{{item.durationMinutes}}分钟</view>
      <view class="chip">{{item.exerciseSets.length}}组</view>
      <view class="chip">疲劳{{item.fatigueLevel}}</view>
    </view>
    <view class="record-exercises" wx:if="{{item.exerciseSets.length > 0}}">
      <text wx:for="{{item.exerciseSets}}" wx:key="index" wx:for-item="set" class="exercise-text">
        {{set.exerciseName}} {{set.weight}}kg×{{set.reps}}
      </text>
    </view>
  </view>
</view>