<view class="container">
  <!-- 总览卡片 -->
  <view class="stats-overview">
    <view class="overview-card">
      <text class="overview-value">{{totalWorkouts}}</text>
      <text class="overview-label">总训练次数</text>
    </view>
    <view class="overview-card">
      <text class="overview-value">{{totalDuration}}</text>
      <text class="overview-label">总时长(分钟)</text>
    </view>
    <view class="overview-card">
      <text class="overview-value">{{currentStreak}}</text>
      <text class="overview-label">当前连续</text>
    </view>
    <view class="overview-card">
      <text class="overview-value">{{longestStreak}}</text>
      <text class="overview-label">最长连续</text>
    </view>
  </view>

  <!-- 本周统计 -->
  <view class="card">
    <text class="section-title">本周训练</text>
    <view class="weekly-chart">
      <view wx:for="{{weeklyStats}}" wx:key="day" class="chart-bar-item">
        <view class="bar-wrapper">
          <view class="bar-fill" style="height: {{item.barHeight}}%; background-color: {{item.hasWorkout ? '#F8FAFC' : '#2D3748'}};"></view>
        </view>
        <text class="bar-label">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- 部位统计 -->
  <view class="card">
    <text class="section-title">部位分布</text>
    <view wx:for="{{tagStats}}" wx:key="tag" class="tag-stat-item">
      <view class="tag-stat-header">
        <view class="flex-row">
          <view class="tag-indicator" style="background-color: {{item.color}};"></view>
          <text class="tag-stat-name">{{item.name}}</text>
        </view>
        <text class="tag-stat-count">{{item.count}}次 / {{item.duration}}分钟</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{item.count / totalWorkouts * 100}}%; background-color: {{item.color}};"></view>
      </view>
    </view>
  </view>

  <!-- 月度统计 -->
  <view class="card">
    <text class="section-title">月度统计</text>
    <view wx:for="{{monthlyStats}}" wx:key="month" class="monthly-item">
      <text class="monthly-name">{{item.month}}</text>
      <view class="monthly-info">
        <text class="monthly-count">{{item.count}}次</text>
        <text class="monthly-duration">{{item.duration}}分钟</text>
      </view>
    </view>
  </view>
</view>