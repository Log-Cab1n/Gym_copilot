.stats-overview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 24rpx;
}

.overview-card {
  background: linear-gradient(145deg, #1A1F2E, #1A1F2E);
  border-radius: 28rpx;
  padding: 44rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(45, 55, 72, 0.6);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3), 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.overview-card:active {
  transform: scale(0.97);
}

.overview-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #F8FAFC;
  line-height: 1.2;
}

.overview-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
  margin-top: 12rpx;
}

.weekly-chart {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-end;
  height: 240rpx;
  padding: 40rpx 0 20rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 32rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background: linear-gradient(180deg, #1A1F2E, #242B3D);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.bar-fill {
  width: 100%;
  border-radius: 16rpx;
  transition: height 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.bar-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #64748B;
  margin-top: 16rpx;
}

.tag-stat-item {
  margin-bottom: 32rpx;
}

.tag-stat-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tag-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.tag-stat-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #F8FAFC;
}

.tag-stat-count {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
}

.progress-bar {
  height: 8rpx;
  background: linear-gradient(90deg, #1A1F2E, #242B3D);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.monthly-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(36, 43, 61, 0.8);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.monthly-item:active {
  transform: scale(0.98);
}

.monthly-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #F8FAFC;
}

.monthly-info {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.monthly-count {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
}

.monthly-duration {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748B;
}