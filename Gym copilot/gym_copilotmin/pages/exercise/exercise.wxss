.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #0B0F19;
}

/* 搜索框 */
.search-box {
  padding: 32rpx 40rpx 24rpx;
}

.search-input-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(145deg, #1A1F2E, #0B0F19);
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.5);
  transition: all 0.2s ease;
}

.search-input-wrapper:focus-within {
  border-color: rgba(232, 228, 225, 0.2);
  box-shadow: 0 0 0 2rpx rgba(232, 228, 225, 0.05), 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #F8FAFC;
  height: 44rpx;
  font-weight: 500;
}

.search-placeholder {
  color: #64748B;
}

.search-clear {
  font-size: 24rpx;
  color: #64748B;
  padding: 12rpx;
  margin-left: 8rpx;
  border-radius: 50%;
  transition: all 0.15s ease;
  min-width: 64rpx;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear:active {
  background-color: rgba(232, 228, 225, 0.1);
  color: #F8FAFC;
}

/* 标签筛选 */
.tag-filter-scroll {
  height: 96rpx;
  margin-bottom: 8rpx;
}

.tag-filter {
  display: flex;
  flex-direction: row;
  padding: 0 32rpx;
  height: 96rpx;
  align-items: center;
  gap: 16rpx;
}

.tag-item {
  padding: 18rpx 36rpx;
  background: linear-gradient(145deg, #1A1F2E, #1A1F2E);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #64748B;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  white-space: nowrap;
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tag-item:active {
  transform: scale(0.92);
}

.tag-active {
  background: linear-gradient(135deg, #F8FAFC, #D4D0CD);
  color: #0B0F19;
  border-color: rgba(232, 228, 225, 0.3);
  box-shadow: 0 6rpx 20rpx rgba(232, 228, 225, 0.2);
  font-weight: 700;
  transform: translateY(-2rpx);
}

/* 动作列表 */
.exercise-list-scroll {
  flex: 1;
  padding: 0 32rpx;
}

.exercise-list {
  padding-bottom: 180rpx;
}

.exercise-card {
  background: linear-gradient(145deg, #1A1F2E, #0B0F19);
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15), 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.exercise-card:active {
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.exercise-card-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx;
}

/* 左侧图标 */
.exercise-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #242B3D, #1A1F2E);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.exercise-icon-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #F8FAFC;
}

/* 中间信息 */
.exercise-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.exercise-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.exercise-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.meta-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #242B3D, #1A1F2E);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.meta-icon {
  font-size: 20rpx;
  margin-right: 8rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #64748B;
  font-weight: 500;
}

/* 右侧信息 */
.exercise-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.date-tag {
  margin-bottom: 16rpx;
}

.delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(207, 102, 121, 0.15), rgba(207, 102, 121, 0.08));
  border: 1rpx solid rgba(207, 102, 121, 0.1);
  transition: all 0.15s ease;
}

.delete-btn:active {
  transform: scale(0.85);
  background: linear-gradient(135deg, rgba(207, 102, 121, 0.25), rgba(207, 102, 121, 0.15));
}

.delete-icon {
  font-size: 24rpx;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #F8FAFC, #D4D0CD);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4), 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  z-index: 50;
  transition: all 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.add-btn:active {
  transform: scale(0.88);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.add-btn-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: #0B0F19;
  line-height: 1;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(8rpx);
}

.modal-mask-show {
  opacity: 1;
}

/* 底部弹窗 */
.bottom-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1A1F2E, #1A1F2E);
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.bottom-sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 64rpx;
  height: 6rpx;
  background: linear-gradient(to right, #2D3748, #2D3748);
  border-radius: 3rpx;
  margin: 24rpx auto 20rpx;
}

.sheet-content {
  padding: 24rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.sheet-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 32rpx;
}

.sheet-icon {
  margin-right: 24rpx;
}

.sheet-title-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.sheet-subtitle {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 500;
}

.sheet-divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, #2D3748, transparent);
  margin: 24rpx 0;
}

.sheet-actions {
  margin-top: 8rpx;
}

/* 详情行 */
.detail-rows {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
}

.detail-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #242B3D, #1A1F2E);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.detail-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #F8FAFC;
}

/* 历史记录 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(145deg, #1A1F2E, #1A1F2E);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.history-set-number {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #242B3D, #1A1F2E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.history-datetime {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.history-weight-reps {
  font-size: 30rpx;
  font-weight: 700;
  color: #F8FAFC;
}

.history-fatigue {
  background: linear-gradient(135deg, #242B3D, #1A1F2E);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #64748B;
  flex-shrink: 0;
  font-weight: 500;
  border: 1rpx solid rgba(45, 55, 72, 0.3);
}

.history-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.history-empty-text {
  font-size: 28rpx;
  color: #64748B;
}

/* 添加弹窗 */
.modal-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1A1F2E, #1A1F2E);
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.modal-popup-show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid rgba(45, 55, 72, 0.4);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #F8FAFC;
  letter-spacing: 1rpx;
}

.modal-close {
  font-size: 32rpx;
  color: #64748B;
  padding: 12rpx;
  border-radius: 50%;
  transition: all 0.15s ease;
  min-width: 64rpx;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close:active {
  background-color: rgba(232, 228, 225, 0.1);
  color: #F8FAFC;
}

.modal-body {
  padding: 32rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
}

.modal-section-title {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 20rpx;
  margin-top: 8rpx;
  font-weight: 600;
}

.modal-input {
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #F8FAFC;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  font-weight: 500;
  transition: all 0.15s ease;
}

.modal-input:focus {
  border-color: rgba(232, 228, 225, 0.2);
}

.input-placeholder {
  color: #64748B;
}

.tag-select {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.tag-option {
  padding: 18rpx 32rpx;
  background: linear-gradient(145deg, #242B3D, #1A1F2E);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #64748B;
  border: 1rpx solid rgba(45, 55, 72, 0.4);
  font-weight: 600;
  transition: all 0.2s ease;
}

.tag-option:active {
  transform: scale(0.92);
}

.tag-option-active {
  background: linear-gradient(135deg, #F8FAFC, #D4D0CD);
  color: #0B0F19;
  border-color: rgba(232, 228, 225, 0.3);
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(232, 228, 225, 0.15);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #F8FAFC, #D4D0CD);
  color: #0B0F19;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(232, 228, 225, 0.15);
  transition: all 0.15s ease;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(232, 228, 225, 0.1);
}

.modal-btn {
  width: 100%;
  padding: 32rpx 0;
  margin-top: 16rpx;
  border-radius: 28rpx;
}

.history-btn {
  width: 100%;
  padding: 32rpx 0;
  border-radius: 28rpx;
}

button::after {
  border: none;
}
